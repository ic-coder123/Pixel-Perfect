; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Pixel Perfect"
run/main_scene="uid://dwmw3qx7u2d03"
config/features=PackedStringArray("4.7", "GL Compatibility")
boot_splash/image="uid://cuaqhofhwmrn5"
config/icon="uid://dut6d1s3ojo3e"
boot_splash/minimum_display_time=100

[autoload]

Main="*uid://dapa7tmgx58s4"
MetSys="*uid://c01ibpvrp2wsd"
Dialogic="*uid://ds2q0uclmolvu"

[dialogic]

directories/dch_directory={
"Guide": "res://Guide.dch",
"Statue of power": "res://DialogueResources/Characters/Statue of power.dch",
"You": "res://DialogueResources/Dialogue/You.dch"
}
directories/dtl_directory={
"DoubleJumpAbility": "res://DialogueResources/Dialogue/DoubleJumpAbility.dtl",
"GuideBeggining": "res://DialogueResources/Dialogue/GuideBeggining.dtl"
}
layout/style_directory={}
extensions_folder="res://addons/dialogic_additions"
text/letter_speed=0.01
text/initial_text_reveal_skippable=true
text/text_reveal_skip_delay=0.1
text/advance_delay=0.1
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
animations/join_default_length=0.5
animations/join_default_wait=true
animations/leave_default_length=0.5
animations/leave_default_wait=true
animations/cross_fade_default_length=0.5
choices/autofocus_first=true
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
save/autosave_delay=60.0
save/encryption_on_exports_only=true
translation/enabled=false
translation/original_locale="en"
translation/file_mode=1
translation/translation_folder=""
translation/save_mode=0
translation/add_separator=false
text/autopauses={}
audio/channel_defaults={
"": {
"audio_bus": "",
"fade_length": 0.0,
"loop": false,
"volume": 0.0
},
"music": {
"audio_bus": "",
"fade_length": 0.0,
"loop": true,
"volume": 0.0
}
}
glossary/default_case_sensitive=true
layout/style_list=[]
layout/default_style="Default"

[dotnet]

project/assembly_name="Pixel Perfect"

[editor_plugins]

enabled=PackedStringArray("res://addons/MetroidvaniaSystem/plugin.cfg", "res://addons/dialogic/plugin.cfg", "res://addons/drag_and_drop/plugin.cfg", "res://addons/sprite_painter/plugin.cfg")

[global_group]

enemy=""
hazard=""

